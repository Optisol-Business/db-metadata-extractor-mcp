{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
  "name": "io.github.optisol-business/db-metadata-extractor-mcp",
  "description": "Database schema metadata extraction MCP server for PostgreSQL, Snowflake, SQL Server, BigQuery, and Oracle.",
  "version": "0.1.1",
  "repository": {
    "url": "https://github.com/Optisol-Business/db-metadata-extractor-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registry_type": "pypi",
      "identifier": "db-metadata-extractor-mcp",
      "version": "0.1.1",
      "runtime_hint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "environment_variables": [
        {
          "name": "DB_TYPE",
          "description": "Database type: postgresql, snowflake, sqlserver, bigquery, or oracle",
          "is_required": false
        },
        {
          "name": "DB_HOST",
          "description": "Database host address",
          "is_required": false
        },
        {
          "name": "DB_PORT",
          "description": "Database port number",
          "is_required": false,
          "format": "number"
        },
        {
          "name": "DB_USER",
          "description": "Database username",
          "is_required": false
        },
        {
          "name": "DB_PASSWORD",
          "description": "Database password",
          "is_required": false,
          "is_secret": true
        },
        {
          "name": "DB_NAME",
          "description": "Database name",
          "is_required": false
        }
      ]
    }
  ]
}